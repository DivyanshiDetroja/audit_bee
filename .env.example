# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# Postgres (matches docker-compose service name "db")
DATABASE_URL=postgresql://postgres:postgres@db:5432/auditbee

# Anthropic Claude API key — required for document processing
ANTHROPIC_API_KEY=sk-ant-...

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# CORS: the frontend origin allowed to call the API
# Local dev: http://localhost:5173
# Production: your Vercel URL, e.g. https://audit-bee.vercel.app
CORS_ORIGIN=http://localhost:5173

# App environment
APP_ENV=development

# ── Frontend (Vite build-time — only needed for production builds) ─────────────
# Leave blank for local dev (Vite proxy handles /api/* → backend).
# For Vercel deployment, set this in the Vercel project environment variables:
# VITE_API_BASE_URL=https://audit-bee-api.onrender.com
